# Database
DATABASE_URL=sqlite:///./rfq_copilot.db

# Application
APP_ENV=development
APP_DEBUG=false
APP_PORT=8003

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://openai-internship-01.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_INTENT_DEPLOYMENT=
AZURE_OPENAI_TIMEOUT_SECONDS=30.0

# Downstream services
MANAGER_BASE_URL=http://localhost:18000
INTELLIGENCE_BASE_URL=http://localhost:18001
IAM_SERVICE_URL=http://localhost:8004

# Auth bypass
AUTH_BYPASS_ENABLED=false
AUTH_BYPASS_USER_ID=v1-demo-user
AUTH_BYPASS_USER_NAME=System
AUTH_BYPASS_ROLE=estimation_dept_lead
AUTH_BYPASS_DEBUG_HEADERS_ENABLED=false